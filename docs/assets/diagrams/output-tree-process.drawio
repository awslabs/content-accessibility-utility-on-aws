<mxfile host="gen_diagrams.py">
  <diagram name="output-tree-process" id="output-tree-process">
    <mxGraphModel dx="700" dy="250" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="700" pageHeight="250" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="root" value="output-directory/" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fontFamily=monospace;fontSize=12;fillColor=#f5f5f5;strokeColor=#b3b3b3;" vertex="1" parent="1">
          <mxGeometry x="40" y="30" width="620" height="34" as="geometry"/>
        </mxCell>
        <mxCell id="html" value="html/  — converted HTML + extracted images" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fontFamily=monospace;fontSize=12;fillColor=#f5f5f5;strokeColor=#b3b3b3;" vertex="1" parent="1">
          <mxGeometry x="90" y="78" width="570" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="audit" value="audit_report.[json|html|txt]  — audit report" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fontFamily=monospace;fontSize=12;fillColor=#f5f5f5;strokeColor=#b3b3b3;" vertex="1" parent="1">
          <mxGeometry x="90" y="114" width="570" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="rem" value="remediated_NAME.html  — final remediated HTML" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fontFamily=monospace;fontSize=12;fillColor=#f5f5f5;strokeColor=#b3b3b3;" vertex="1" parent="1">
          <mxGeometry x="90" y="150" width="570" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="note" value="(remediated_document.html with --single-page; remediated_html/ with --multi-page)" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fontFamily=monospace;fontSize=12;fillColor=#f5f5f5;strokeColor=#b3b3b3;fontColor=#777777;" vertex="1" parent="1">
          <mxGeometry x="140" y="186" width="520" height="40" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
